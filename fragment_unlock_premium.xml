<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Top Content -->
    <ImageView
        android:id="@+id/iconViewUnlockPremium"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/chef_with_hat"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="56dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/headlineLabelUnlockPremium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unlimited Items"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toBottomOf="@id/iconViewUnlockPremium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/contentLabelUnlockPremium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add an unlimited number of new items."
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/headlineLabelUnlockPremium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- Main Action -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/makePurchaseButtonUnlockPremium"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Unlock Premium"
        android:textSize="18sp"
        android:textStyle="bold"
        android:icon="@drawable/ic_cart_white"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:cornerRadius="32dp"
        app:backgroundTint="@color/secondary_light"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/contentLabelUnlockPremium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"/>

    <!-- Close Button at Bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/closeButtonUnlockPremium"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="@string/close"
        style="?attr/materialButtonOutlinedStyle"
        app:cornerRadius="24dp"
        app:backgroundTint="@android:color/white"
        android:textColor="@color/text_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
