<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- Custom Toolbar Include -->
    <include
        android:id="@+id/custom_toolbar_planning"
        layout="@layout/custom_toolbar_shopping"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Large page title below toolbar -->
    <TextView
        android:id="@+id/planningTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/shopping_list"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/custom_toolbar_planning"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Section header (Other) -->
    <TextView
        android:id="@+id/sectionHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="#7A7A7A"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/planningTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- RecyclerView for items -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/upcomingRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        app:layout_constraintTop_toBottomOf="@id/sectionHeader"
        app:layout_constraintBottom_toTopOf="@id/deleteButtonShopping"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Empty label (only visible when list is empty) -->
    <TextView
        android:id="@+id/tutorialLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Empty"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textColor="#FFEE8B60"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="32dp"/>

    <!-- "Remove completed" button -->
    <Button
        android:id="@+id/deleteButtonShopping"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remove completed"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
