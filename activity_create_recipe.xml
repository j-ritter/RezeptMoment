<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ededed">

    <!-- Save Button (top-right) -->
    <Button
        android:id="@+id/buttonSave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save"
        android:textStyle="bold"
        android:textColor="#222"
        android:background="@android:color/transparent"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="20dp" />

    <!-- Title below save -->
    <EditText
        android:id="@+id/inputTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Recipe title"
        android:inputType="textCapSentences"
        android:textSize="24sp"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_below="@id/buttonSave"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="26dp"
        android:layout_marginBottom="12dp" />

    <!-- Category Spinner -->
    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/inputTitle"
        android:layout_marginBottom="18dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:textColor="#646464"
        android:textSize="20sp"
        android:textStyle="bold"/>

    <!-- Servings Section -->
    <RelativeLayout
        android:id="@+id/servingsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@id/spinnerCategory"
        android:layout_marginTop="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/servingsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/people"
            android:textColor="#646464"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/servingsMinus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_left_1"
            android:background="@android:color/transparent"
            android:layout_alignParentEnd="false"
            android:layout_toStartOf="@id/servingsCount"
            android:layout_centerVertical="true"
            />

        <TextView
            android:id="@+id/servingsCount"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="2"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textColor="#646464"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_toStartOf="@id/servingsPlus"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/servingsPlus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_right_1"
            android:background="@android:color/transparent"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            />
    </RelativeLayout>

    <!-- Clickable Image Area -->
    <FrameLayout
        android:id="@+id/imageContainer"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="#F6F6F7"
        android:layout_below="@id/servingsSection"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="24dp"
        android:layout_gravity="center_horizontal"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_camera"
            android:contentDescription="@string/recipe_image"
            android:clickable="true"
            android:focusable="true"
            app:tint="#9f9f9f" />
    </FrameLayout>

    <!-- Ingredients Section -->
    <LinearLayout
        android:id="@+id/ingredientsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/imageContainer"
        android:orientation="horizontal"
        android:layout_marginTop="18dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/ingredientsLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ingredients"
            android:textColor="#646464"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="0dp" />

        <ImageView
            android:id="@+id/addIngredient"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_add"
            android:contentDescription="@string/add_ingredient"
            android:clickable="true"
            android:focusable="true"
            app:tint="#646464" />
    </LinearLayout>

    <ListView
        android:id="@+id/ingredientsListView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp"
        android:layout_below="@id/ingredientsSection"
        android:layout_marginBottom="8dp"
        android:background="@android:color/white"
        android:visibility="gone"/>

    <!-- Instructions Section -->
    <LinearLayout
        android:id="@+id/instructionsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/ingredientsListView"
        android:orientation="horizontal"
        android:layout_marginTop="28dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/instructionsLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Instructions"
            android:textColor="#646464"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="0dp" />

        <ImageView
            android:id="@+id/addInstruction"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_add"
            android:contentDescription="@string/add_instruction"
            android:clickable="true"
            android:focusable="true"
            app:tint="#646464" />
    </LinearLayout>

    <ListView
        android:id="@+id/instructionsListView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp"
        android:layout_below="@id/instructionsSection"
        android:background="@android:color/white"
        android:visibility="gone"/>

    <!-- Attachments Section -->
    <LinearLayout
        android:id="@+id/attachmentsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/instructionsListView"
        android:orientation="horizontal"
        android:layout_marginTop="28dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/attachmentsLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Attachments"
            android:textColor="#646464"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="0dp" />

        <ImageView
            android:id="@+id/addAttachment"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_add"
            android:contentDescription="Add Attachment"
            android:clickable="true"
            android:focusable="true"
            app:tint="#646464"/>
    </LinearLayout>

    <ListView
        android:id="@+id/attachmentsListView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="240dp"
        android:layout_below="@id/attachmentsSection"
        android:background="@android:color/white"
        android:visibility="gone" />

    <!-- Cancel Button, Bottom Center -->
    <Button
        android:id="@+id/buttonCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textColor="#aaaaaa"
        android:background="@android:color/transparent"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="22dp"/>
</RelativeLayout>
